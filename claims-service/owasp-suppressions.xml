<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        OWASP Dependency-Check Suppressions
        ====================================
        False positives and accepted risks are documented here.

        RULES:
        1. Never suppress without a justification comment
        2. Always include a review date — suppressions expire and must be re-evaluated
        3. If exploitable in our context — FIX IT, do not suppress
        4. CVSS >= 7: must be fixed unless genuinely unexploitable with documented evidence

        DevSecOps pipeline gate:
        mvn dependency-check:check -DfailBuildOnCVSS=7
        Any CVSS >= 7 with no suppression will FAIL the build.
    -->

    <!--
        EXAMPLE SUPPRESSION (not active — for demonstration):

        <suppress>
            <notes>
                CVE-2022-42003: jackson-databind excessive memory consumption.
                JUSTIFICATION: We do not use the affected deserialization feature (ObjectMapper.readValue
                with DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES disabled).
                All our API inputs are validated with @Valid before deserialization.
                RISK: Low in our context.
                REVIEW DATE: 2025-01-01 — check if patch is available in next Spring Boot release.
                FIXED IN: jackson-databind 2.14.1 — update pom.xml when Spring Boot BOM supports it.
            </notes>
            <cve>CVE-2022-42003</cve>
        </suppress>
    -->

</suppressions>
